APP_NAME="Mi Tienda"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://mitienda.com
APP_ADMIN_URL=admin
APP_TIMEZONE=America/Bogota

APP_LOCALE=es
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=es_CO

APP_CURRENCY=COP

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=tienda
DB_USERNAME=tienda_user
DB_PASSWORD=CAMBIAR_PASSWORD_SEGURO
DB_PREFIX=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=tienda_

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

RESPONSE_CACHE_ENABLED=true

MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=tu-email@gmail.com
MAIL_PASSWORD=tu-app-password

MAIL_FROM_ADDRESS=info@mitienda.com
MAIL_FROM_NAME="${APP_NAME}"
ADMIN_MAIL_ADDRESS=admin@mitienda.com
ADMIN_MAIL_NAME=Admin
CONTACT_MAIL_ADDRESS=contacto@mitienda.com
CONTACT_MAIL_NAME=Contacto

VITE_APP_NAME="${APP_NAME}"

ELASTICSEARCH_HOST=http://elasticsearch:9200

# Wompi - Producción
WOMPI_SANDBOX=false
WOMPI_PUBLIC_KEY=pub_prod_TU_LLAVE_PUBLICA
WOMPI_PRIVATE_KEY=prv_prod_TU_LLAVE_PRIVADA
WOMPI_INTEGRITY_KEY=prod_integrity_TU_LLAVE_INTEGRIDAD
WOMPI_EVENTS_KEY=prod_events_TU_LLAVE_EVENTOS
